generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String
  avatarUrl     String?
  role          String    @default("customer") // "owner" | "customer"
  plan          String    @default("free") // "free" | "pro" | "team"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projects      Project[]
  feedbacks     Feedback[]
  upvotes       Upvote[]
  comments      Comment[]
  subscription  Subscription?
}

model Subscription {
  id                 String    @id @default(cuid())
  userId             String    @unique
  stripeCustomerId   String?   @unique
  stripeSubscriptionId String? @unique
  stripePriceId      String?
  status             String    @default("inactive") // active, canceled, past_due, inactive
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id            String    @id @default(cuid())
  ownerId       String
  name          String
  slug          String    @unique
  description   String?
  logoUrl       String?
  websiteUrl    String?
  customDomain  String?   @unique
  customCss     String?
  webhookUrl    String?
  primaryColor  String    @default("#6366f1")
  isPublic      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  owner         User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  boards        Board[]
  feedbacks     Feedback[]
  roadmapItems  RoadmapItem[]
  changelogs    ChangelogEntry[]
  webhooks      Webhook[]
}

model Board {
  id            String    @id @default(cuid())
  projectId     String
  name          String
  slug          String
  position      Int       @default(0)
  createdAt     DateTime  @default(now())

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  feedbacks     Feedback[]

  @@unique([projectId, slug])
}

model Feedback {
  id            String    @id @default(cuid())
  projectId     String
  authorId      String?
  boardId       String?
  title         String
  description   String
  status        String    @default("open") // open, under_review, planned, in_progress, completed, closed
  category      String    @default("feature") // feature, bug, improvement, question
  upvoteCount   Int       @default(0)
  authorName    String?   // For anonymous submissions
  authorEmail   String?   // For anonymous submissions
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author        User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  board         Board?    @relation(fields: [boardId], references: [id], onDelete: SetNull)
  upvotes       Upvote[]
  comments      Comment[]
  roadmapItem   RoadmapItem?
}

model Upvote {
  id            String    @id @default(cuid())
  feedbackId    String
  userId        String?
  anonymousId   String?   // For anonymous upvotes (IP hash or fingerprint)
  createdAt     DateTime  @default(now())

  feedback      Feedback  @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([feedbackId, userId])
  @@unique([feedbackId, anonymousId])
}

model Comment {
  id            String    @id @default(cuid())
  feedbackId    String
  authorId      String?
  content       String
  isOfficial    Boolean   @default(false)
  authorName    String?   // For display when author is null
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  feedback      Feedback  @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  author        User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model RoadmapItem {
  id            String    @id @default(cuid())
  projectId     String
  feedbackId    String?   @unique
  title         String
  description   String?
  status        String    @default("planned") // planned, in_progress, completed
  quarter       String?
  position      Int       @default(0)
  eta           DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  feedback      Feedback? @relation(fields: [feedbackId], references: [id], onDelete: SetNull)
}

model ChangelogEntry {
  id            String    @id @default(cuid())
  projectId     String
  title         String
  content       String
  version       String?
  type          String    @default("feature") // feature, improvement, bugfix, breaking
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Webhook {
  id            String    @id @default(cuid())
  projectId     String
  name          String
  url           String
  method        String    @default("POST") // GET, POST, PUT, PATCH
  headers       String?   // JSON string of key-value pairs
  enabled       Boolean   @default(true)
  content       String?   // JSON body template, supports {{variables}}
  eventType     String    @default("feedback.created") // feedback.created, feedback.updated, comment.created, upvote.created
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
